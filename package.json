{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "predev": "npm run typecheck && vitest run",
    "dev": "vite --host",
    "check": "npm run typecheck && npm run test",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "check:boundaries:self-test": "node scripts/check-package-boundaries.mjs --self-test",
    "clean:dist": "node scripts/clean-dist.mjs",
    "dev:server": "node scripts/run-server-dev.mjs",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"scripts/**/*.{js,mjs}\" \"*.{ts,tsx,js,jsx,json,css,html,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"scripts/**/*.{js,mjs}\" \"*.{ts,tsx,js,jsx,json,css,html,md}\"",
    "build": "npm run clean:dist && npm run build:standalone && npm run build:client && npm run build:server",
    "build:client": "vite build -c vite.client.config.ts",
    "build:server": "vite build -c vite.server.config.ts",
    "build:standalone": "vite build -c vite.standalone.config.ts",
    "preview": "npm run serve:standalone",
    "preview:client": "npm run serve:client",
    "preview:standalone": "npm run serve:standalone",
    "start:server": "node dist/server/main.js",
    "typecheck": "npm run check:boundaries && npm run typecheck --workspaces",
    "test": "vitest --run",
    "serve:client": "serve dist/client",
    "serve:dist": "serve dist",
    "serve:standalone": "serve dist/standalone"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "serve": "^14.2.5",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
