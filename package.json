{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "predev": "npm run typecheck && vitest run",
    "dev": "vite --host",
    "check": "npm run typecheck && npm run test",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "check:boundaries:self-test": "node scripts/check-package-boundaries.mjs --self-test",
    "dev:server": "node scripts/run-server-dev.mjs",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"scripts/**/*.{js,mjs}\" \"*.{ts,tsx,js,jsx,json,css,html,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"scripts/**/*.{js,mjs}\" \"*.{ts,tsx,js,jsx,json,css,html,md}\"",
    "build": "vite build",
    "preview": "vite preview",
    "start:server": "node scripts/run-server-dist.mjs",
    "typecheck": "npm run check:boundaries && npm run typecheck --workspaces",
    "test": "vitest --run",
    "serve:dist": "serve dist"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "serve": "^14.2.5",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
