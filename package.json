{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build": "npm run clean:dist && npm run build:plugins && npm run bundle:standalone && npm run bundle:client && npm run bundle:server",
    "build:browser-plugins": "node scripts/build-plugin-packs.mjs browser && node scripts/assemble-browser-plugins.mjs",
    "build:client": "npm run build:browser-plugins && npm run bundle:client",
    "build:plugins": "node scripts/build-plugin-packs.mjs all && node scripts/assemble-browser-plugins.mjs && node scripts/assemble-server-plugins.mjs",
    "build:server": "npm run build:server-plugins && npm run bundle:server",
    "build:server-plugins": "node scripts/build-plugin-packs.mjs server && node scripts/assemble-server-plugins.mjs",
    "build:standalone": "npm run build:browser-plugins && npm run bundle:standalone",
    "bundle:client": "vite build -c vite.client.config.ts",
    "bundle:server": "vite build -c vite.server.config.ts",
    "bundle:standalone": "vite build -c vite.standalone.config.ts",
    "check": "npm run typecheck && npm run test",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "check:boundaries:self-test": "node scripts/check-package-boundaries.mjs --self-test",
    "clean:dist": "node scripts/clean-dist.mjs",
    "dev": "npm run check && npm run build:plugins && vite --host",
    "dev:client": "npm run build:browser-plugins && VITE_SOLITUDE_SERVER_URL=http://localhost:8787 vite -c vite.client.config.ts --host",
    "dev:server": "npm run build:plugins && node scripts/run-server-dev.mjs",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"plugins/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"scripts/**/*.{js,mjs}\" \"*.{ts,tsx,js,jsx,json,css,html,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"plugins/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"scripts/**/*.{js,mjs}\" \"*.{ts,tsx,js,jsx,json,css,html,md}\"",
    "load:server": "node scripts/run-server-load.mjs",
    "map:architecture": "node scripts/generate-architecture-map.mjs",
    "serve:client": "serve -c ../../packages/client/serve.json dist/client",
    "serve:standalone": "serve dist/standalone",
    "start:server": "node dist/server/main.js",
    "test": "vitest --run",
    "typecheck": "npm run check:boundaries && npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dependency-cruiser": "^17.4.3",
    "elkjs": "^0.11.1",
    "prettier": "3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "serve": "^14.2.5",
    "ts-morph": "^28.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
