{
  "type": "module",
  "scripts": {
    "predev": "npm run typecheck && vitest run",
    "dev": "vite --host",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"*.{ts,tsx,js,jsx,json,css,html,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"*.{ts,tsx,js,jsx,json,css,html,md}\"",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "serve:dist": "serve dist"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "serve": "^14.2.5",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
